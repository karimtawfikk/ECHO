def initialize_entity_config(entity_type: str, entity_name: str):
    """
    Initialize the global configuration for a specific entity
    This mimics what happens in main() but programmatically
    """
    # Set global variables in the phase6_edgetts module
    phase6_edgetts.ENTITY_TYPE = entity_type
    phase6_edgetts.ENTITY_NAME = entity_name
    
    cfg = ENTITY_CONFIG[entity_type]
    
    # Build vector SQL
    phase6_edgetts.VECTOR_SQL = SQL_TEMPLATE.format(
        texts_table=cfg["texts_table"],
        entities_table=cfg["entities_table"],
        entity_id_col=cfg["entity_id_col"]
    )
    
    # Build rewrite chain
    prompt_key = cfg["prompt_key"]
    query_rewriter_llm = ChatGroq(
        model_name=phase6_edgetts.GROQ_QUERY_REWRITER_MODEL_NAME,
        temperature=0.2,
        max_tokens=1024,
        api_key=os.getenv("GROQ_API_KEY1"),
        extra_body={"reasoning_effort": "default", "reasoning_format": "hidden"}
    )
    phase6_edgetts.rewrite_chain = (
        PromptTemplate.from_template(PROMPTS["rewrite_prompt"][prompt_key]) | 
        query_rewriter_llm | 
        StrOutputParser()
    )
    
    # Build LLM prompt template
    phase6_edgetts.llm_prompt_template = PromptTemplate.from_template(
        PROMPTS["assistant_persona"][prompt_key]
    )



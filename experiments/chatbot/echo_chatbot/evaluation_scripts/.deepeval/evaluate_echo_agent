def compute_ragas_metrics(results: List[Dict], ragas_emb) -> Dict[str, float]:
    """
    Computes Ragas metrics using YOUR factory instance.
    """
    print("\nComputing Ragas metrics with Groq llama-3.3-70b...")
    
    successful_results = [r for r in results if r.get("success") and r.get("answer")]
    if not successful_results:
        return {}

    # 1. Dataset Preparation
    ragas_dataset = Dataset.from_dict({
        "user_input": [r["question"] for r in successful_results],
        "response": [r["answer"] for r in successful_results],
        "retrieved_contexts": [r["contexts"] if r.get("contexts") else ["No context"] for r in successful_results],
        "reference": [r["ground_truth"] for r in successful_results]
    })
    
    # 2. Setup Wrappers
    evaluator_llm = ChatGroq(
        model="llama-3.3-70b-versatile", 
        api_key=os.getenv("GROQ_API_KEY3"), 
        temperature=0
    )
    ragas_llm = LangchainLLMWrapper(evaluator_llm)

    # --- THE FIX ---
    # We wrap your ragas_emb so it provides the 'embed_query' method metrics need.
    # We use the BaseRagasEmbeddings wrapper to keep it native to Ragas.
    from ragas.embeddings import LangchainEmbeddingsWrapper
    ragas_emb_fixed = LangchainEmbeddingsWrapper(ragas_emb)
    try:
        from ragas.metrics import Faithfulness, AnswerRelevancy, ContextPrecision, ContextRecall

        # 3. Initialize Metrics
        metrics = [
            Faithfulness(llm=ragas_llm),
            AnswerRelevancy(llm=ragas_llm, embeddings=ragas_emb_fixed, strictness=1), 
            ContextPrecision(llm=ragas_llm),
            ContextRecall(llm=ragas_llm)
        ]
        
        # 4. Execute Evaluation
        evaluation_result = evaluate(
            dataset=ragas_dataset,
            metrics=metrics,
            llm=ragas_llm,
            embeddings=ragas_emb_fixed,
            #run_config=RunConfig(max_workers=1, timeout=120),
            raise_exceptions=False 
        )
        
        # 5. Extraction
        df_scores = evaluation_result.to_pandas()
        summary_scores = df_scores.mean(numeric_only=True).to_dict()
        
        return {
            k: float(v) if not np.isnan(v) else 0.0 
            for k, v in summary_scores.items()
        }
        
    except Exception as e:
        print(f" ✗ Error during evaluation: {e}")
        return {}


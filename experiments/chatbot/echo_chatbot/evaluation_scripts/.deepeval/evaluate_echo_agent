def run_evaluation(test_df: pd.DataFrame) -> List[Dict[str, Any]]:
    """
    Run the chatbot on all test cases with fresh memory for each
    """
    print(f"\n{'='*80}")
    print(f"Running evaluation on {len(test_df)} test cases...")
    print(f"{'='*80}\n")
    
    results = []
    current_entity = None
    
    for idx, row in test_df.iterrows():
        entity_key = (row['entity_type'], row['entity_name'])
        
        # Only reinitialize if entity changed
        if current_entity != entity_key:
            print(f"\n[SWITCHING ENTITY] Initializing {row['entity_type']}: {row['entity_name']}")
            initialize_entity_config(row['entity_type'], row['entity_name'])
            current_entity = entity_key
        
        print(f"[{idx+1}/{len(test_df)}] Testing: {row['entity_name']} - {row['input'][:60]}...")
        
        start_time = time.time()
        
        try:
            # Create unique thread_id for fresh memory
            config = {"configurable": {"thread_id": f"eval-{idx}"}}
            
            # Invoke the graph
            response = graph.invoke(
                {
                    "messages": [("user", row["input"])],
                    "query": row["input"],
                    "context": [],
                    "voice_mode": False
                },
                config=config
            )
            messages = response.get("messages", [])
            has_actually_searched = any(isinstance(m, ToolMessage) for m in messages)
            
            end_time = time.time()
            
            # Extract response and context
            answer = response.get("response", "")
            contexts = response.get("context", [])
            
            # Ensure contexts is a list
            if isinstance(contexts, str):
                contexts = [contexts]
            elif not isinstance(contexts, list):
                contexts = []
            
            # Store result
            results.append({
                "question": row["input"],
                "answer": answer,
                "contexts": contexts,
                "ground_truth": row["expected_output"],
                "response_time": end_time - start_time,
                "entity_type": row["entity_type"],
                "entity_name": row["entity_name"],
                "success": True,
                
                # ADD THESE for more metrics later:
                "retrieved_before_rerank": response.get("context_before_rerank", []),
                "answer_length": len(answer.split()),
                "num_tool_calls": 1 if has_actually_searched else 0
            })
            
            print(f"  ✓ Response time: {end_time - start_time:.2f}s | Contexts: {len(contexts)}")
            
        except Exception as e:
            print(f"  ✗ Error: {str(e)}")
            results.append({
                "question": row["input"],
                "answer": "",
                "contexts": [],
                "ground_truth": row["expected_output"],
                "ground_truth_context": [],
                "response_time": 0,
                "entity_type": row["entity_type"],
                "entity_name": row["entity_name"],
                "success": False,
                "error": str(e)
            })
        
        time.sleep(1.2)
    
    successful = sum(1 for r in results if r["success"])
    print(f"\n{'='*80}")
    print(f"Evaluation complete! {successful}/{len(results)} successful")
    print(f"{'='*80}\n")
    
    return results


